{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/web/$1"
        }
    ],
    "builds": [
        {
            "src": "web/package.json",
            "use": "@vercel/next"
        },
        {
            "src": "api/*.py",
            "use": "@vercel/python"
        }
    ]
}